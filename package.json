{
  "name": "@tsd-ui/root",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "clean": "rimraf ./dist && npm run clean -ws --if-present",
    "clean:all": "npm run clean:all -ws --if-present && rimraf ./dist ./node_modules",
    "dist": "rimraf ./dist && copyfiles -e 'node_modules/**' entrypoint.sh '**/package.json' '*/dist/**/*' ./dist",
    "lint": "npm run lint -ws --if-present",
    "lint:fix": "npm run lint:fix -ws --if-present",
    "format": "npm run format -ws --if-present",
    "format:fix": "npm run format:fix -ws --if-present",
    "build": "npm run build -ws --if-present",
    "start:dev:common": "npm run start:dev -w common",
    "start:dev:client": "npm run start:dev -w client",
    "start:dev": "npm run build -w common && concurrently -n common,client -c 'white.bold.inverse,green.bold.inverse' 'npm:start:dev:common' 'npm:start:dev:client'",
    "start": "npm run build -w common -w client && npm run start -w server",
    "test": "npm run build -w common && npm run test -w common -w client -w server --if-present --"
  },
  "workspaces": [
    "common",
    "client",
    "server"
  ],
  "dependencies": {
    "@types/express": "^5.0.3",
    "http-proxy-middleware": "^3.0.5"
  },
  "peerDependencies": {
    "react": "^18 || ^19.0.0",
    "react-dom": "^18 || ^19.0.0",
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.7.7",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-run": "^3.1.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/plugin-virtual": "^3.0.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.0.0",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.0.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.0.1",
    "rollup": "^4.62.2",
    "rollup-plugin-copy": "^3.5.0",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "typescript-eslint": "^8.59.3"
  }
}
