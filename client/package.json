{
  "name": "@tsd-ui/client",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf ./dist",
    "clean:all": "rimraf ./dist ./node_modules",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check './src/**/*.{ts,tsx,js,json}'",
    "format:fix": "prettier --write './src/**/*.{ts,tsx,js,json}'",
    "start:dev": "vite --port 3000 --host",
    "start": "vite preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "preview": "vite preview"
  },
  "dependencies": {
    "@patternfly/patternfly": "^6.2.0",
    "@patternfly/react-core": "^6.4.1",
    "@patternfly/react-table": "^6.4.1",
    "@patternfly/react-tokens": "^6.2.0",
    "@tanstack/react-query": "^5.61.0",
    "@tanstack/react-query-devtools": "^5.85.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "tsd-ui": "github:tsd-ui/tsd-ui#v0.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^28.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-ejs": "^2.0.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
